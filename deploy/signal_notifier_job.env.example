PROJECT_ID=papersignalquant
REGION=asia-southeast1

# Copy this file per notifier job. Keep one paper-signal project, but give
# each strategy its own JOB_NAME/SCHEDULER_JOB_NAME/IMAGE/STATE_URI/SNAPSHOT_URI.
JOB_NAME=paper-signal-coin-short-hold
SCHEDULER_JOB_NAME=paper-signal-coin-short-hold-daily
CRON_SCHEDULE="45 15 * * 1-5"
TIME_ZONE=America/New_York
SOURCE_DIR=/home/ubuntu/Projects/PaperSignalPlatform
DOCKERFILE_PATH=Dockerfile.signal-notifier
IMAGE=asia-southeast1-docker.pkg.dev/papersignalquant/paper-signal-platform/coin-short-hold:latest
SERVICE_ACCOUNT=paper-signal-runner@papersignalquant.iam.gserviceaccount.com
SCHEDULER_SERVICE_ACCOUNT=paper-signal-scheduler@papersignalquant.iam.gserviceaccount.com

SCRIPT_PATH=scripts/send_coin_short_hold_signal.py
# EXTRA_COPY_PATHS=path/to/extra_dir,path/to/extra_file.py
LOOKBACK_DAYS=900
NOTIFY_LANG=zh
# Optional: used only to translate target weight into buy/sell dollar hints.
# SIGNAL_NOTIFY_REFERENCE_CAPITAL_USD=100000
STATE_URI=gs://papersignalquant-signal-artifacts/paper-signal/coin-short-hold/state.json
SNAPSHOT_URI=gs://papersignalquant-signal-artifacts/paper-signal/coin-short-hold/latest.json

# Dedicated notify-only bot.
STDOUT_ONLY=false
SKIP_UNCHANGED=true
FORCE_SEND=false

SIGNAL_NOTIFY_TELEGRAM_CHAT_ID=5992562050
TELEGRAM_TOKEN_SECRET_NAME=paper-signal-telegram-token
