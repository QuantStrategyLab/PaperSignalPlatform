PROJECT_ID=papersignalquant
REGION=asia-southeast1

# Grouped tool-choice strategy signal.
JOB_NAME=paper-signal-grouped-tool-choice
SCHEDULER_JOB_NAME=paper-signal-grouped-tool-choice-daily
CRON_SCHEDULE="45 15 * * 1-5"
TIME_ZONE=America/New_York
SOURCE_DIR=/home/ubuntu/Projects/PaperSignalPlatform
DOCKERFILE_PATH=Dockerfile.signal-notifier
IMAGE=asia-southeast1-docker.pkg.dev/papersignalquant/paper-signal-platform/grouped-tool-choice:latest
SERVICE_ACCOUNT=paper-signal-runner@papersignalquant.iam.gserviceaccount.com
SCHEDULER_SERVICE_ACCOUNT=paper-signal-scheduler@papersignalquant.iam.gserviceaccount.com

SCRIPT_PATH=scripts/send_grouped_tool_choice_signal.py
LOOKBACK_DAYS=900
NOTIFY_LANG=zh
# Optional current MAGS7 constituents. Removed configured routes are excluded;
# new unconfigured symbols are ignored until a specialist route is designed.
# MAGS7_UNIVERSE=AAPL,AMZN,GOOGL,NVDA,MSFT,META,TSLA
# Optional: used only to translate target weight into dollar hints.
# SIGNAL_NOTIFY_REFERENCE_CAPITAL_USD=100000
STATE_URI=gs://papersignalquant-signal-artifacts/paper-signal/grouped-tool-choice/state.json
SNAPSHOT_URI=gs://papersignalquant-signal-artifacts/paper-signal/grouped-tool-choice/latest.json

# Dedicated strategy signal bot.
STDOUT_ONLY=false
SKIP_UNCHANGED=true
FORCE_SEND=false

SIGNAL_NOTIFY_TELEGRAM_CHAT_ID=5992562050
TELEGRAM_TOKEN_SECRET_NAME=paper-signal-telegram-token
