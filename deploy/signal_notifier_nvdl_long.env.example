PROJECT_ID=papersignalquant
REGION=asia-southeast1

# Legacy MAGS notifier. The script name is retained, but it now runs the
# MAGS7-only grouped tool-choice strategy.
JOB_NAME=paper-signal-mags7-tool-choice
SCHEDULER_JOB_NAME=paper-signal-mags7-tool-choice-daily
CRON_SCHEDULE="45 15 * * 1-5"
TIME_ZONE=America/New_York
SOURCE_DIR=/home/ubuntu/Projects/PaperSignalPlatform
DOCKERFILE_PATH=Dockerfile.signal-notifier
IMAGE=asia-southeast1-docker.pkg.dev/papersignalquant/paper-signal-platform/mags7-tool-choice:latest
SERVICE_ACCOUNT=paper-signal-runner@papersignalquant.iam.gserviceaccount.com
SCHEDULER_SERVICE_ACCOUNT=paper-signal-scheduler@papersignalquant.iam.gserviceaccount.com

SCRIPT_PATH=scripts/send_nvdl_long_signal.py
LOOKBACK_DAYS=900
NOTIFY_LANG=zh
# Optional current constituents. Removed configured routes are excluded; new
# unconfigured symbols are ignored until a specialist route is designed.
# MAGS7_UNIVERSE=AAPL,AMZN,GOOGL,NVDA,MSFT,META,TSLA
# Optional: used only to translate target weight into buy/sell dollar hints.
# SIGNAL_NOTIFY_REFERENCE_CAPITAL_USD=100000
STATE_URI=gs://papersignalquant-signal-artifacts/paper-signal/mags7-tool-choice/state.json
SNAPSHOT_URI=gs://papersignalquant-signal-artifacts/paper-signal/mags7-tool-choice/latest.json

# Dedicated notify-only bot.
STDOUT_ONLY=false
SKIP_UNCHANGED=true
FORCE_SEND=false

SIGNAL_NOTIFY_TELEGRAM_CHAT_ID=5992562050
TELEGRAM_TOKEN_SECRET_NAME=paper-signal-telegram-token
