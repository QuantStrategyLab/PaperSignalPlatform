PROJECT_ID=quantstrategylab-paper-signal
REGION=asia-southeast1
JOB_NAME=paper-signal-incident-actions-sg
IMAGE=asia-southeast1-docker.pkg.dev/quantstrategylab-paper-signal/paper-signal-platform/app:latest
SERVICE_ACCOUNT=paper-signal-runner@quantstrategylab-paper-signal.iam.gserviceaccount.com

PYTHON_COMMAND=python
ACTION_SCRIPT_PATH=scripts/execute_incident_review_actions.py
ACTION_BACKEND=gcs
PAPER_SIGNAL_GCS_BUCKET=quantstrategylab-paper-signal-artifacts
ACTION_GCS_PREFIX=paper-signal/sg
ACTION_STRATEGY_PROFILE=
ACTION_PAPER_ACCOUNT_GROUP=
ACTION_PERIOD=daily
ACTION_REGION_CODE=sg
ACTION_MAX_TRIGGERS=15
ACTION_MIN_SEVERITY=critical
ACTION_MAX_REVIEWS=2
ACTION_AS_OF=
ACTION_START_DATE=
ACTION_END_DATE=
ACTION_EXECUTE=false

REVIEW_JOB_NAME=paper-signal-ops-review-pack-sg
REVIEW_SCRIPT_PATH=scripts/print_operator_review_pack.py
REVIEW_BACKEND=gcs
REVIEW_GCS_PREFIX=paper-signal/sg
REVIEW_ARTIFACT_DIR=.paper_signal/artifacts
REVIEW_MAX_BOOKS=10
REVIEW_MAX_EVENTS=20
REVIEW_SEND_TELEGRAM=true
REVIEW_TELEGRAM_CHAT_ID=

NOTIFY_LANG=en

SCHEDULER_JOB_NAME=paper-signal-incident-actions-sg-daily
CRON_SCHEDULE=12 21 * * 1-5
TIME_ZONE=Asia/Singapore
SCHEDULER_SERVICE_ACCOUNT=paper-signal-scheduler@quantstrategylab-paper-signal.iam.gserviceaccount.com
