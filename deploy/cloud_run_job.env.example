PROJECT_ID=quantstrategylab-paper-signal
REGION=asia-southeast1
JOB_NAME=paper-signal-soxl-sg
IMAGE=asia-southeast1-docker.pkg.dev/quantstrategylab-paper-signal/paper-signal-platform/app:latest
SERVICE_ACCOUNT=paper-signal-runner@quantstrategylab-paper-signal.iam.gserviceaccount.com

STRATEGY_PROFILE=soxl_soxx_trend_income
PAPER_ACCOUNT_GROUP=sg_soxl_notify
PAPER_ACCOUNT_GROUP_CONFIG_SECRET_NAME=paper-account-groups

PAPER_SIGNAL_STATE_STORE_BACKEND=firestore
PAPER_SIGNAL_FIRESTORE_COLLECTION=paper_signal_states
PAPER_SIGNAL_ARTIFACT_STORE_BACKEND=gcs
PAPER_SIGNAL_GCS_BUCKET=quantstrategylab-paper-signal-artifacts
PAPER_SIGNAL_MARKET_DATA_PROVIDER=yfinance
PAPER_SIGNAL_HISTORY_LOOKBACK_DAYS=420

GLOBAL_TELEGRAM_CHAT_ID=
NOTIFY_LANG=en

TELEGRAM_TOKEN_SECRET_NAME=telegram-token

SCHEDULER_JOB_NAME=paper-signal-soxl-sg-daily
CRON_SCHEDULE=5 21 * * 1-5
TIME_ZONE=Asia/Singapore
SCHEDULER_SERVICE_ACCOUNT=paper-signal-scheduler@quantstrategylab-paper-signal.iam.gserviceaccount.com
